NODE_ENV=development
APP_TIMEZONE=Europe/Bucharest
APP_VERSION=1.0.0

MONDAY_API_TOKEN=
MONDAY_API_URL=https://api.monday.com/v2
MONDAY_API_VERSION=2025-01

ORDERS_BOARD_ID=2030349838
REQUESTS_BOARD_ID=1905911565

# Default: 08:00 on the 1st of every month (timezone = APP_TIMEZONE)
CRON_SCHEDULE=0 8 1 * *
# When true, send email even if zero mismatches
SEND_EMPTY_REPORT=false
# When true (and SEND_EMPTY_REPORT), attach the Excel on empty runs too
ATTACH_REPORT_ON_EMPTY=false
REPORT_OUTPUT_DIR=./output

SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
MAIL_FROM=
MAIL_TO=
MAIL_CC=
MAIL_BCC=

LOG_LEVEL=info
